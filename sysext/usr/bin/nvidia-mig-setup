#!/usr/bin/env bash
# Recreates MIG instances on boot from persistent config.
# Baked into nvidia-mig.raw sysext; runs as a systemd oneshot started
# by a TrueNAS PREINIT entry (registered by install-sysext.sh) before
# docker.service.
#
# Config file: /mnt/<pool>/.config/nvidia-gpu/mig.conf
# Never exits non-zero — must not block boot.

set -uo pipefail

log() { echo "[nvidia-mig-setup] $*"; }

log "Starting nvidia-mig-setup (boot: $(cat /proc/sys/kernel/random/boot_id 2>/dev/null || echo unknown))"

# --- Wait for the NVIDIA driver to be actually responsive ---
# Three distinct race conditions are folded into this one wait:
#   1. Stock-driver-merge race. The stock NVIDIA sysext may still be
#      merging asynchronously when this oneshot is queued (After=
#      systemd-sysext.service is not always sufficient).
#   2. Custom-driver-restore race. With install-sysext.sh --with-driver,
#      a sibling PREINIT (nvidia-preinit-driver) may be re-applying a
#      custom nvidia.raw on this boot. The two PREINITs are unordered;
#      we accept either ordering and just wait for the resulting driver
#      to come up.
#   3. Module-load race. Even when /usr/bin/nvidia-smi exists, the
#      kernel module loads asynchronously via udev/modprobe — until
#      that completes, nvidia-smi calls fail with NVML errors.
# So we wait for the binary AND for the binary to actually return GPU
# info — `nvidia-smi -L` only succeeds when NVML can talk to the module.
# 60s ceiling is empirically enough; if the driver isn't up by then,
# nothing this script does will fix it.
#
# Progress logging: log start of wait + an elapsed-time update every 10s,
# so `journalctl -u nvidia-mig-setup` shows clear timing instead of a
# silent hang. Skipping per-iteration logs keeps the journal readable.
NVIDIA_DRIVER_TIMEOUT=60
NVIDIA_DRIVER_POLL_INTERVAL=2
NVIDIA_READY=false
elapsed=0
logged_initial=false
while [ "$elapsed" -lt "$NVIDIA_DRIVER_TIMEOUT" ]; do
    if [ -x /usr/bin/nvidia-smi ] && /usr/bin/nvidia-smi -L >/dev/null 2>&1; then
        NVIDIA_READY=true
        break
    fi
    if ! $logged_initial; then
        if [ -x /usr/bin/nvidia-smi ]; then
            log "Waiting for NVIDIA driver to become responsive (kernel module may still be loading); timeout=${NVIDIA_DRIVER_TIMEOUT}s..."
        else
            log "Waiting for /usr/bin/nvidia-smi (sysext may still be merging); timeout=${NVIDIA_DRIVER_TIMEOUT}s..."
        fi
        logged_initial=true
    elif [ "$((elapsed % 10))" -eq 0 ] && [ "$elapsed" -gt 0 ]; then
        log "  still waiting for NVIDIA driver... ${elapsed}s/${NVIDIA_DRIVER_TIMEOUT}s"
    fi
    sleep "$NVIDIA_DRIVER_POLL_INTERVAL"
    elapsed=$((elapsed + NVIDIA_DRIVER_POLL_INTERVAL))
done

if ! $NVIDIA_READY; then
    if [ ! -x /usr/bin/nvidia-smi ]; then
        log "/usr/bin/nvidia-smi not available after ${NVIDIA_DRIVER_TIMEOUT}s, skipping MIG setup"
    else
        log "/usr/bin/nvidia-smi present but driver did not become responsive after ${NVIDIA_DRIVER_TIMEOUT}s, skipping MIG setup"
        log "(diagnostic: check 'journalctl -b -t nvidia-preinit-driver' if you used --with-driver, and 'dmesg | grep -i nvidia')"
    fi
    exit 0
fi
$logged_initial && log "NVIDIA driver responsive after ${elapsed}s"

# --- Find config via glob (handles any pool name) ---
CONFIG=""
for f in /mnt/*/.config/nvidia-gpu/mig.conf; do
    [ -f "$f" ] && CONFIG="$f" && break
done

if [ -z "$CONFIG" ]; then
    log "No MIG config found at /mnt/*/.config/nvidia-gpu/mig.conf, skipping"
    exit 0
fi

log "Using config: $CONFIG"
# shellcheck disable=SC1090
source "$CONFIG"

if [ -z "${MIG_PROFILES:-}" ]; then
    log "MIG_PROFILES not set in $CONFIG, skipping"
    exit 0
fi

# --- Ensure MIG mode is enabled ---
MIG_MODE=$(/usr/bin/nvidia-smi --query-gpu=mig.mode.current --format=csv,noheader 2>/dev/null || echo "N/A")
if [ "$MIG_MODE" != "Enabled" ]; then
    log "MIG mode not enabled (current: $MIG_MODE), enabling..."
    /usr/bin/nvidia-smi -mig 1 2>/dev/null || { log "ERROR: Failed to enable MIG mode"; exit 0; }
    MIG_MODE=$(/usr/bin/nvidia-smi --query-gpu=mig.mode.current --format=csv,noheader 2>/dev/null || echo "N/A")
    if [ "$MIG_MODE" != "Enabled" ]; then
        log "MIG mode enabled but pending reboot (current: $MIG_MODE)"
        exit 0
    fi
    log "MIG mode enabled"
fi

# --- Recreate MIG instances (idempotent) ---
log "Destroying existing MIG instances..."
/usr/bin/nvidia-smi mig -dci 2>/dev/null || true
/usr/bin/nvidia-smi mig -dgi 2>/dev/null || true

log "Creating MIG instances: $MIG_PROFILES"
if ! /usr/bin/nvidia-smi mig -cgi "$MIG_PROFILES" -C; then
    log "ERROR: Failed to create MIG instances"
    exit 0
fi

log "MIG instances created successfully"
/usr/bin/nvidia-smi mig -lgi 2>/dev/null || true

# --- Remap app GPU UUIDs ---
# All MIG profiles (including +gfx) are compute-capable.
# MIG UUIDs change on every reboot because instances are volatile.
# Update any TrueNAS apps that have stale MIG UUID assignments.

ALL_MIG_UUIDS=()
while IFS= read -r line; do
    if echo "$line" | grep -q 'MIG.*UUID:'; then
        uuid=$(echo "$line" | sed -n 's/.*UUID: \([^)]*\)).*/\1/p')
        [ -n "$uuid" ] && ALL_MIG_UUIDS+=("$uuid")
    fi
done < <(/usr/bin/nvidia-smi -L 2>/dev/null)

if [ "${#ALL_MIG_UUIDS[@]}" -eq 0 ]; then
    log "No MIG UUIDs found, skipping app remap"
    exit 0
fi

# Use first MIG UUID for app remapping
COMPUTE_UUID="${ALL_MIG_UUIDS[0]}"
log "First MIG UUID: $COMPUTE_UUID"

# --- Update TrueNAS app GPU assignments ---
# Wait for middleware to be ready (it may still be starting at PREINIT time).
# Time-based so the journal shows clear elapsed seconds rather than opaque
# "attempt N/M" counters.
#
# 120s (was 25s): on a real cold boot — especially right after a major TrueNAS
# upgrade — middleware can take well over 25s to answer system.ready. When it
# isn't ready the app-UUID remap below silently no-ops, leaving GPU apps pointed
# at stale MIG UUIDs ("UUID Not Found"). The PREINIT timeout (300s) and the
# preceding driver wait (60s) leave ample headroom for this longer wait.
MIDDLEWARE_TIMEOUT=120
MIDDLEWARE_POLL_INTERVAL=5
mid_elapsed=0
mid_logged_initial=false
mid_ready=false
while [ "$mid_elapsed" -lt "$MIDDLEWARE_TIMEOUT" ]; do
    # system.ready returns a Python-style boolean: midclt prints it as `True`
    # (capitalized), NOT lowercase JSON `true`. A case-sensitive `grep -q true`
    # therefore NEVER matched — so this wait always ran to its full timeout even
    # on a fully-ready system, and the app remap below silently no-op'd (apps
    # lost their MIG UUID pins on every boot). Match case-insensitively.
    # (configure-mig.sh compares to the literal "True" for this same reason.)
    if midclt call system.ready 2>/dev/null | grep -qiw true; then
        mid_ready=true
        break
    fi
    if ! $mid_logged_initial; then
        log "Waiting for TrueNAS middleware to be ready (system.ready); timeout=${MIDDLEWARE_TIMEOUT}s..."
        mid_logged_initial=true
    else
        log "  still waiting for middleware... ${mid_elapsed}s/${MIDDLEWARE_TIMEOUT}s"
    fi
    sleep "$MIDDLEWARE_POLL_INTERVAL"
    mid_elapsed=$((mid_elapsed + MIDDLEWARE_POLL_INTERVAL))
done
if $mid_ready && $mid_logged_initial; then
    log "Middleware ready after ${mid_elapsed}s"
elif ! $mid_ready; then
    log "Middleware not ready after ${MIDDLEWARE_TIMEOUT}s; proceeding anyway (app remap may fail and is non-fatal)"
fi

# Get GPU PCI slot
PCI_SLOT=$(midclt call app.gpu_choices 2>/dev/null \
    | python3 -c "
import sys, json
try:
    choices = json.load(sys.stdin)
    for slot, info in choices.items():
        if isinstance(info, dict):
            vendor = (info.get('vendor') or '').upper()
            desc = (info.get('description') or '').upper()
            if 'NVIDIA' in vendor or 'NVIDIA' in desc:
                print(slot, end='')
                break
        elif isinstance(info, str) and 'NVIDIA' in info.upper():
            print(slot, end='')
            break
except Exception:
    pass
" 2>/dev/null)

if [ -z "$PCI_SLOT" ]; then
    log "Could not detect GPU PCI slot, skipping app remap"
    exit 0
fi

log "GPU PCI slot: $PCI_SLOT"

# Build the app.update payload with python3 (slot and uuid passed as argv)
# instead of interpolating into a JSON string literal, to avoid quoting and
# escaping fragility. Loop-invariant, so build it once.
MIG_UPDATE_PAYLOAD=$(python3 -c '
import json, sys
slot, uuid = sys.argv[1], sys.argv[2]
print(json.dumps({"values": {"resources": {"gpus": {
    "use_all_gpus": False,
    "nvidia_gpu_selection": {slot: {"use_gpu": True, "uuid": uuid}},
}}}}))
' "$PCI_SLOT" "$COMPUTE_UUID")

# Query all apps and find ones with existing MIG UUID assignments
midclt call app.query 2>/dev/null | python3 -c "
import sys, json

try:
    apps = json.load(sys.stdin)
except Exception:
    sys.exit(0)

pci_slot = '$PCI_SLOT'
new_uuid = '$COMPUTE_UUID'

for app in apps:
    name = app.get('name', '')
    # Navigate the nested config to find GPU selection
    active_workloads = app.get('active_workloads', {})
    # Check current config for nvidia_gpu_selection
    config = app.get('config', {}) or {}
    resources = config.get('resources', {}) or {}
    gpus = resources.get('gpus', {}) or {}
    gpu_sel = gpus.get('nvidia_gpu_selection', {}) or {}

    for slot, slot_cfg in gpu_sel.items():
        if isinstance(slot_cfg, dict) and slot_cfg.get('uuid', ''):
            old_uuid = slot_cfg['uuid']
            if old_uuid.startswith('MIG-') and old_uuid != new_uuid:
                print(f'{name}:{old_uuid}')
" 2>/dev/null | while IFS=: read -r app_name old_uuid; do
    log "Updating $app_name: $old_uuid -> $COMPUTE_UUID"
    midclt call app.update "$app_name" "$MIG_UPDATE_PAYLOAD" 2>/dev/null \
        && log "  Updated $app_name successfully" \
        || log "  WARNING: Failed to update $app_name"
done

log "MIG setup complete"
exit 0
