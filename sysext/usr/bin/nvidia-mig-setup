#!/usr/bin/env bash
# Recreates MIG instances on boot from persistent config.
# Baked into nvidia-mig.raw sysext (or nvidia.raw in full-driver builds);
# runs as a systemd oneshot before docker.service.
#
# Config file: /mnt/<pool>/.config/nvidia-gpu/mig.conf
# Never exits non-zero — must not block boot.

set -uo pipefail

log() { echo "[nvidia-mig-setup] $*"; }

# --- Find config via glob (handles any pool name) ---
CONFIG=""
for f in /mnt/*/.config/nvidia-gpu/mig.conf; do
    [ -f "$f" ] && CONFIG="$f" && break
done

if [ -z "$CONFIG" ]; then
    log "No MIG config found at /mnt/*/.config/nvidia-gpu/mig.conf, skipping"
    exit 0
fi

log "Using config: $CONFIG"
# shellcheck disable=SC1090
source "$CONFIG"

if [ -z "${MIG_PROFILES:-}" ]; then
    log "MIG_PROFILES not set in $CONFIG, skipping"
    exit 0
fi

# --- Ensure MIG mode is enabled ---
MIG_MODE=$(/usr/bin/nvidia-smi --query-gpu=mig.mode.current --format=csv,noheader 2>/dev/null || echo "N/A")
if [ "$MIG_MODE" != "Enabled" ]; then
    log "MIG mode not enabled (current: $MIG_MODE), enabling..."
    /usr/bin/nvidia-smi -mig 1 2>/dev/null || { log "ERROR: Failed to enable MIG mode"; exit 0; }
    MIG_MODE=$(/usr/bin/nvidia-smi --query-gpu=mig.mode.current --format=csv,noheader 2>/dev/null || echo "N/A")
    if [ "$MIG_MODE" != "Enabled" ]; then
        log "MIG mode enabled but pending reboot (current: $MIG_MODE)"
        exit 0
    fi
    log "MIG mode enabled"
fi

# --- Recreate MIG instances (idempotent) ---
log "Destroying existing MIG instances..."
/usr/bin/nvidia-smi mig -dci 2>/dev/null || true
/usr/bin/nvidia-smi mig -dgi 2>/dev/null || true

log "Creating MIG instances: $MIG_PROFILES"
if ! /usr/bin/nvidia-smi mig -cgi "$MIG_PROFILES" -C; then
    log "ERROR: Failed to create MIG instances"
    exit 0
fi

log "MIG instances created successfully"
/usr/bin/nvidia-smi mig -lgi 2>/dev/null || true

# --- Remap app GPU UUIDs ---
# All MIG profiles (including +gfx) are compute-capable.
# MIG UUIDs change on every reboot because instances are volatile.
# Update any TrueNAS apps that have stale MIG UUID assignments.

ALL_MIG_UUIDS=()
while IFS= read -r line; do
    if echo "$line" | grep -q 'MIG.*UUID:'; then
        uuid=$(echo "$line" | sed -n 's/.*UUID: \([^)]*\)).*/\1/p')
        [ -n "$uuid" ] && ALL_MIG_UUIDS+=("$uuid")
    fi
done < <(/usr/bin/nvidia-smi -L 2>/dev/null)

if [ "${#ALL_MIG_UUIDS[@]}" -eq 0 ]; then
    log "No MIG UUIDs found, skipping app remap"
    exit 0
fi

# Use first MIG UUID for app remapping
COMPUTE_UUID="${ALL_MIG_UUIDS[0]}"
log "First MIG UUID: $COMPUTE_UUID"

# --- Update TrueNAS app GPU assignments ---
# Wait for middleware to be ready (it may still be starting)
for attempt in 1 2 3 4 5; do
    if midclt call system.ready 2>/dev/null | grep -q true; then
        break
    fi
    log "Waiting for TrueNAS middleware (attempt $attempt/5)..."
    sleep 5
done

# Get GPU PCI slot
PCI_SLOT=$(midclt call app.gpu_choices 2>/dev/null \
    | python3 -c "
import sys, json
try:
    choices = json.load(sys.stdin)
    for slot, info in choices.items():
        if isinstance(info, dict):
            vendor = (info.get('vendor') or '').upper()
            desc = (info.get('description') or '').upper()
            if 'NVIDIA' in vendor or 'NVIDIA' in desc:
                print(slot, end='')
                break
        elif isinstance(info, str) and 'NVIDIA' in info.upper():
            print(slot, end='')
            break
except Exception:
    pass
" 2>/dev/null)

if [ -z "$PCI_SLOT" ]; then
    log "Could not detect GPU PCI slot, skipping app remap"
    exit 0
fi

log "GPU PCI slot: $PCI_SLOT"

# Query all apps and find ones with existing MIG UUID assignments
midclt call app.query 2>/dev/null | python3 -c "
import sys, json

try:
    apps = json.load(sys.stdin)
except Exception:
    sys.exit(0)

pci_slot = '$PCI_SLOT'
new_uuid = '$COMPUTE_UUID'

for app in apps:
    name = app.get('name', '')
    # Navigate the nested config to find GPU selection
    active_workloads = app.get('active_workloads', {})
    # Check current config for nvidia_gpu_selection
    config = app.get('config', {}) or {}
    resources = config.get('resources', {}) or {}
    gpus = resources.get('gpus', {}) or {}
    gpu_sel = gpus.get('nvidia_gpu_selection', {}) or {}

    for slot, slot_cfg in gpu_sel.items():
        if isinstance(slot_cfg, dict) and slot_cfg.get('uuid', ''):
            old_uuid = slot_cfg['uuid']
            if old_uuid.startswith('MIG-') and old_uuid != new_uuid:
                print(f'{name}:{old_uuid}')
" 2>/dev/null | while IFS=: read -r app_name old_uuid; do
    log "Updating $app_name: $old_uuid -> $COMPUTE_UUID"
    midclt call app.update "$app_name" "{\"values\":{\"resources\":{\"gpus\":{\"use_all_gpus\":false,\"nvidia_gpu_selection\":{\"$PCI_SLOT\":{\"use_gpu\":true,\"uuid\":\"$COMPUTE_UUID\"}}}}}}" 2>/dev/null \
        && log "  Updated $app_name successfully" \
        || log "  WARNING: Failed to update $app_name"
done

log "MIG setup complete"
exit 0
